# ============================================================
# PirateHunt — Environment Configuration
# ============================================================
# Copy this file to .env and fill in values:
#   cp .env.example .env
# ============================================================

# --- Database (PostgreSQL with pgvector) ---
DATABASE_URL=postgresql+asyncpg://piratehunt:piratehunt@localhost:5433/piratehunt

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- FAISS Index Path ---
FAISS_INDEX_PATH=./data/visual_index.faiss

# --- Logging ---
LOG_LEVEL=INFO

# --- Gemini API (optional — for AI verification & DMCA polishing) ---
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# --- DMCA Settings (optional) ---
DMCA_GEMINI_POLISH_ENABLED=true
DMCA_GENERATION_TIMEOUT_SECONDS=30
DMCA_DEFAULT_LANGUAGE=en
