# ============================================================
# PirateHunt — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/

# --- Virtual Environments ---
venv/
.venv/
env/
ENV/

# --- Environment / Secrets ---
.env
.env.local

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db

# --- Node.js (dashboard) ---
node_modules/
.next/
dashboard/node_modules/
dashboard/.next/
dashboard/.env
dashboard/.env.local

# --- Testing ---
htmlcov/
.coverage
.coverage.*
.pytest_cache/
.hypothesis/

# --- Project-specific ---
*.faiss
data/
evidence/
tests/fixtures/*.mp4

# --- Alembic cache ---
alembic/__pycache__/
alembic/versions/__pycache__/
